# wiki-base — repo hygiene
#
# IMPORTANT: .wiki/ is intentionally NOT ignored. The wiki is "just a git repo
# of markdown files" (Karpathy) — commit it alongside your code so you get
# history, branching, and collaboration for free.

# Personal, per-project Claude Code memory (never shared)
CLAUDE.local.md

# Local Claude Code / MCP overrides and secrets (opt-in MCP setup is private)
.claude/settings.local.json
.mcp.local.json
.env
.env.*
*.local

# OS / editor junk
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
*.swp
*~

# Optional: if your team stores large binary attachments outside git,
# uncomment to keep them out of the repo (the wiki text still references them).
# .wiki/assets/*
# !.wiki/assets/.gitkeep
